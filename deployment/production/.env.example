PROJECT_NAME=wallet-v2
# 建議填絕對路徑，避免 docker compose 在不同工作目錄執行時路徑錯誤
# 例如：/opt/apps/wallet-v2
PROJECT_PATH=/absolute/path/to/wallet-v2

# Ports
NGINX_HTTP_PORT=8088

# Timezone
TZ=Asia/Taipei

# 注意：應用程式設定（APP_*, DB_*, REDIS_*, QUEUE_CONNECTION, LINE_*, GEMINI_* ...）
# 請放在專案根目錄的 .env（即 ${PROJECT_PATH}/.env），由 Laravel 直接讀取。
